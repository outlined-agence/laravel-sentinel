{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "blank_line_before_statement": {
            "statements": [
                "continue",
                "declare",
                "return",
                "throw",
                "try"
            ]
        },
        "concat_space": {
            "spacing": "one"
        }
    }
}
