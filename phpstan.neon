includes:
    - ./vendor/nunomaduro/larastan/extension.neon

parameters:
    paths:
        - src

    level: 8

    ignoreErrors:
        - '#Call to an undefined method Illuminate\\Contracts\\Auth\\Authenticatable::#'
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::getKey\(\)#'

    excludePaths:
        - src/Filament/*
